{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Article",
  "type": "object",
  "required": ["slug", "title", "description", "seo", "sections"],
  "properties": {
    "slug": {"type": "string"},
    "title": {"type": "string"},
    "subtitle": {"type": "string"},
    "description": {"type": "string"},
    "date": {"type": "string"},
    "readTime": {"type": "string"},
    "category": {"type": "string"},
    "seo": {
      "type": "object",
      "required": ["title", "description"],
      "properties": {
        "title": {"type": "string"},
        "description": {"type": "string"},
        "keywords": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["text", "quote", "image", "stats", "cards", "cta"]
          },
          "heading": {"type": "string"},
          "content": {"type": "string"},
          "items": {"type": "array"},
          "assetKey": {"type": "string"}
        }
      }
    }
  }
}
